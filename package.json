{
  "name": "dnd-companion",
  "version": "2.0.0",
  "description": "Server-authoritative local Wi-Fi D&D companion with DM and player views",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"vite --host 0.0.0.0\" \"node server.js\"",
    "dev:vite": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm.cmd run build && npm.cmd test",
    "link:spell-refs": "node scripts/link-spell-markdown-references.js"
  },
  "keywords": [
    "dnd",
    "combat",
    "tracker",
    "websocket",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "express": "^4.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.6.0",
    "socket.io-client": "^4.8.1",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
